# lightpanda cloud
LIGHTPANDA_TOKEN="your-token-here"

# tinyfish search/fetch_content (X-API-Key); generate at agent.tinyfish.ai/api-keys
TINYFISH_API_KEY="your-key-here"

# omlx server (Mac/Apple Silicon only)
OMLX_BASE_URL="http://127.0.0.1:8000"
OMLX_API_KEY="supersecurepassword"
# set to suppress startup warnings when omlx is unreachable
OMLX_QUIET=1

# pi provider + model — set per machine
# koboldcpp:  PI_DEFAULT_PROVIDER=koboldcpp,  PI_DEFAULT_MODEL=qwen3-coder-next-builder  (80B-A3B no-think; -planner variant for reasoning)
# mbp/studio: PI_DEFAULT_PROVIDER=omlx,       PI_DEFAULT_MODEL=Qwen3.6-35B-A3B-bf16
# wsl:        PI_DEFAULT_PROVIDER=koboldcpp,  PI_DEFAULT_MODEL=qwen3.6-27b-builder
PI_DEFAULT_PROVIDER="koboldcpp"
PI_DEFAULT_MODEL="qwen3-coder-next-builder"
