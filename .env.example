# omlx server (Mac/Apple Silicon only)
OMLX_BASE_URL="http://127.0.0.1:8000"
OMLX_API_KEY="supersecurepassword"

# pi provider + model — set per machine
# mbp/studio: PI_DEFAULT_PROVIDER=omlx,      PI_DEFAULT_MODEL=Qwen3.6-35B-A3B-bf16
# wsl:        PI_DEFAULT_PROVIDER=koboldcpp,  PI_DEFAULT_MODEL=qwen3.6-27b-builder
PI_DEFAULT_PROVIDER="omlx"
PI_DEFAULT_MODEL="Qwen3.6-35B-A3B-bf16"

# WSL only: silence pi-omlx-picker warnings when omlx is not available
# OMLX_BASE_URL="http://disabled"
# OMLX_API_KEY="disabled"
