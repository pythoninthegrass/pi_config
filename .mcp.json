{
  "mcpServers": {
    "backlog": {
      "command": "backlog",
      "args": [
        "mcp", "start"
      ]
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "screencap": {
      "command": "$HOME/.local/bin/uv",
      "args": [
        "--directory",
        "${SCREENCAP_DIR:-$HOME/git/screencap}",
        "run",
        "server.py"
      ],
      "env": {
        "UV_PROJECT_ENVIRONMENT": "$HOME/git/screencap/.venv"
      }
    },
    "serena": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide",
        "--project-from-cwd"
      ]
    }
  }
}
